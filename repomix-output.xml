                  >
                    <X size={12} />
                  </button>
                </div>
              )}
            </div>

            {/* Footer */}
            <div className="flex items-center justify-end gap-3 px-6 py-4 border-t border-[#3A3530]">
              <button
                onClick={closeAwardModal}
                className="px-4 py-2 text-sm text-[#A89888] hover:text-[#F5E6D3] transition-colors"
