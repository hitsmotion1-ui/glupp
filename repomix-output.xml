  bar_review: "Avis de bar",
  submit_beer: "Soumettre une biere",
  submit_bar: "Soumettre un bar",
};

const BUILD_DATE = "2026-02-28";
const VERSION = "Sprint 6 — Admin";

// ═══════════════════════════════════════════
// Page
// ═══════════════════════════════════════════

export default function SettingsPage() {
