"use client";

import { useAdmin } from "@/lib/hooks/useAdmin";
import { AdminHeader } from "@/components/admin/AdminHeader";
import { StatCard } from "@/components/admin/StatCard";
import {
  Users,
  Beer,
  MapPin,
  Sparkles,
  Swords,
